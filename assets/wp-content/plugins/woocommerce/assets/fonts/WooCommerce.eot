<script type="rocketlazyloadscript">
   // 获取 URL 中的 UTM 参数
   function getUTMParameter(name) {
      var urlParams = new URLSearchParams(window.location.search);
      return urlParams.has(name) ? urlParams.get(name) : '';
   }

   // 设置 sessionStorage 和 localStorage
   function setUTMStorage() {
      var utmSource = getUTMParameter('utm_source');
      var utmMedium = getUTMParameter('utm_medium');
      var utmCampaign = getUTMParameter('utm_campaign');
      var utmTerm = getUTMParameter('utm_term');

      // 如果 URL 中有 utm_source，则保存到 sessionStorage 和 localStorage
      if (utmSource) {
         sessionStorage.setItem('utm_source', utmSource);
         // 设置 localStorage，过期时间为7天（7天 = 7 * 24 * 60 * 60 * 1000 毫秒）
         localStorage.setItem('utm_source', utmSource);
         localStorage.setItem('utm_source_expiry', Date.now() + 7 * 24 * 60 * 60 * 1000); // 设置过期时间
      }

      if (utmMedium) {
         sessionStorage.setItem('utm_medium', utmMedium);
         localStorage.setItem('utm_medium', utmMedium);
      }

      if (utmCampaign) {
         sessionStorage.setItem('utm_campaign', utmCampaign);
         localStorage.setItem('utm_campaign', utmCampaign);
      }

      if (utmTerm) {
         sessionStorage.setItem('utm_term', utmTerm);
         localStorage.setItem('utm_term', utmTerm);
      }
   }

   // 检查 localStorage 中的 utm_source 是否过期，如果过期则清除
   function checkUTMExpiry() {
      var expiryTime = localStorage.getItem('utm_source_expiry');
      if (expiryTime && Date.now() > expiryTime) {
         localStorage.removeItem('utm_source');
         localStorage.removeItem('utm_medium');
         localStorage.removeItem('utm_campaign');
         localStorage.removeItem('utm_term');
         localStorage.removeItem('utm_source_expiry');
      }
   }

   // 填充表单中的 UTM 参数
   function fillUTMParameters() {
      var utmSource = sessionStorage.getItem('utm_source') || localStorage.getItem('utm_source');
      var utmMedium = sessionStorage.getItem('utm_medium') || localStorage.getItem('utm_medium');
      var utmCampaign = sessionStorage.getItem('utm_campaign') || localStorage.getItem('utm_campaign');
      var utmTerm = sessionStorage.getItem('utm_term') || localStorage.getItem('utm_term');

      // 查找所有 input[name="utm_source"] 并填充
      document.querySelectorAll('input[name="utm_source"]').forEach(function(input) {
         if (utmSource) {
            input.value = utmSource;
         }
      });

      // 查找所有 input[name="utm_medium"] 并填充
      document.querySelectorAll('input[name="utm_medium"]').forEach(function(input) {
         if (utmMedium) {
            input.value = utmMedium;
         }
      });

      // 查找所有 input[name="utm_campaign"] 并填充
      document.querySelectorAll('input[name="utm_campaign"]').forEach(function(input) {
         if (utmCampaign) {
            input.value = utmCampaign;
         }
      });

      // 查找所有 input[name="utm_term"] 并填充
      document.querySelectorAll('input[name="utm_term"]').forEach(function(input) {
         if (utmTerm) {
            input.value = utmTerm;
         }
      });
   }

   // 页面加载后执行
   document.addEventListener("DOMContentLoaded", function() {
      // 先检查是否需要清除过期的 UTM 数据
      checkUTMExpiry();
      // 设置 UTM 参数到 sessionStorage 和 localStorage
      setUTMStorage();
      // 填充表单中的 UTM 参数
      fillUTMParameters();
   });
</script>
<!-- Hide and Show Desktop Header -->
<script type="rocketlazyloadscript">
var transHeader = document.getElementById("trans-header");
var clientWidth = 1920;
  
document.addEventListener('DOMContentLoaded', function() {  
  clientWidth =  document.body.clientWidth;
}); 
  
window.onscroll = function() {
var currentScrollPos = window.pageYOffset;
  
  if (currentScrollPos > 80) {
    if(clientWidth > 767) {
    	transHeader.style.transform = 'translateY(-50px)';
    }
			
  } else {
    if(clientWidth > 767) {
      transHeader.style.transform = 'translateY(0px)';
    }
  }
}
</script>

